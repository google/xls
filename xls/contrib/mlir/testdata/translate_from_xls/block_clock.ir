// RUN: xls_translate --xls-to-mlir-xls %s 2>&1 | FileCheck %s

package translate_block_clock

// CHECK-LABEL: xls.block @pipeline
// CHECK-SAME: [clock: "clk"]
// CHECK-SAME: (%a: i32) -> (%out : i32)
// CHECK:   xls.register @state : i32
// CHECK:   xls.register_read @state
// CHECK:   xls.add
// CHECK:   xls.register_write @state
// CHECK:   xls.block_output
block pipeline(clk: clock, a: bits[32], out: bits[32]) {
  reg state(bits[32])
  a: bits[32] = input_port(name=a)
  state_q: bits[32] = register_read(register=state)
  sum: bits[32] = add(a, state_q)
  state_d: () = register_write(sum, register=state)
  out: () = output_port(state_q, name=out)
}
