#ifndef XLS_CONTRIB_XLSCC_SYNTH_ONLY_ARRAY_
#define XLS_CONTRIB_XLSCC_SYNTH_ONLY_ARRAY_

#include <cstddef>

namespace std {

template <typename T, size_t N>
struct array {
  T _M_elems[N];

  typedef T value_type;
  typedef T* iterator;
  typedef const T* const_iterator;

  constexpr size_t size() const { return N; }
  constexpr bool empty() const { return N == 0; }

  // ReferenceProxy is used to intercept assignment to std::array elements.
  // Leveraged by Translator::ApplyArrayAssignHack() in translator.cc.
  struct ReferenceProxy {
    T val;
    ReferenceProxy(T v) : val(v) {}
    void operator=(const T& new_val) {}
    void operator=(const ReferenceProxy& other) {}
    operator T() const { return val; }
  };

  ReferenceProxy operator[](size_t index) {
    // NOP to ensure that clang parses the set_element functions
    set_element_bitref(0, _M_elems[0]);
    set_element_xlsint(0, _M_elems[0]);
    set_element_int(0, _M_elems[0]);
    return ReferenceProxy(_M_elems[index]);
  }
  const T& operator[](size_t index) const {
    return _M_elems[index];
  }

  T* data() { return _M_elems; }
  const T* data() const { return _M_elems; }

  iterator begin() { return _M_elems; }
  const_iterator begin() const { return _M_elems; }
  iterator end() { return _M_elems + N; }
  const_iterator end() const { return _M_elems + N; }

  ReferenceProxy at(size_t index) { return ReferenceProxy(_M_elems[index]); }
  const T& at(size_t index) const { return _M_elems[index]; }

  ReferenceProxy front() { return ReferenceProxy(_M_elems[0]); }
  const T& front() const { return _M_elems[0]; }
  ReferenceProxy back() { return ReferenceProxy(_M_elems[N - 1]); }
  const T& back() const { return _M_elems[N - 1]; }

  // These are leveraged by Translator::ApplyArrayAssignHack() to implement
  // assignment via operator.
  void set_element_int(size_t index, const T& val) {
    _M_elems[index] = val;
  }
  void set_element_xlsint(size_t index, const T& val) {
    _M_elems[index] = val;
  }
  void set_element_bitref(size_t index, const T& val) {
    _M_elems[index] = val;
  }
};

}  // namespace std

#endif  // XLS_CONTRIB_XLSCC_SYNTH_ONLY_ARRAY_
