module UMod(
  input wire [31:0] x,
  input wire [31:0] y,
  output wire [31:0] out
);
  function automatic [31:0] umod_32b (input reg [31:0] lhs, input reg [31:0] rhs);
    begin
      umod_32b = rhs == 32'h0000_0000 ? 32'h0000_0000 : lhs % rhs;
    end
  endfunction
  wire [31:0] umod_6;
  assign umod_6 = umod_32b(x, y);
  assign out = umod_6;
endmodule
